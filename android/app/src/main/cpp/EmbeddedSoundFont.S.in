.global xen_soundfont_blob_end
.hidden xen_soundfont_blob_end
.type xen_soundfont_blob_end, %object
xen_soundfont_blob_end:
.size xen_soundfont_blob_start, xen_soundfont_blob_end - xen_soundfont_blob_start

.section .note.GNU-stack,"",%progbits
